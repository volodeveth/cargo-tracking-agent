# External sources
TRACK_TRACE_TIMEOUT=20
NUMBER_TIMEOUT=60
SOURCE_RETRIES=2
MAX_CONCURRENCY=3

# Optional CargoAI API (air cargo) - left empty disables the connector
CARGOAI_API_KEY=

# Optional LLM assistant (off by default)
LLM_ENABLED=false
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=

# Optional Google Sheets export (used by `--format sheets`; falls back to JSON when unset)
SHEETS_SPREADSHEET_ID=
SHEETS_CREDENTIALS_PATH=

# Optional webhook
WEBHOOK_URL=
WEBHOOK_SECRET=

# Scheduler
RECHECK_ENABLED=false
RECHECK_INTERVAL_MINUTES=30

# Cache
CACHE_TTL_MINUTES=60

# Storage / debug
DB_PATH=data/tracking.db
DEBUG_ARTIFACTS=false
DEBUG_DIR=data/debug
